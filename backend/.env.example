# ─── Backend Environment Variables ────────────────────────────────────────────
# Copy this file to .env and fill in the values

# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Atlas
# Get this from MongoDB Atlas → Connect → Connect your application
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/sujju_software?retryWrites=true&w=majority

# Frontend URL (used for CORS — set to your deployed Vercel URL in production)
FRONTEND_URL=http://localhost:5173

# ─── Nodemailer SMTP (Gmail) ───────────────────────────────────────────────────
# For Gmail: Enable 2FA and generate an App Password at:
# https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_EMAIL=your_company_email@gmail.com
SMTP_PASSWORD=your_16_character_app_password
