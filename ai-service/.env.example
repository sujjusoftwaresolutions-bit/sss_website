# ─── AI Service Environment Variables ─────────────────────────────────────────
# Copy this file to .env and fill in the values.

# Port for Flask app (Render sets PORT automatically, so this is optional locally)
FLASK_PORT=5001

# Flask environment (development or production)
FLASK_ENV=development

# When the real YOLOv8 model is integrated, add the path to the weights file:
# MODEL_WEIGHTS_PATH=./model/civicsense_yolov8.pt

# Confidence threshold for YOLOv8 detection
# CONFIDENCE_THRESHOLD=0.6
